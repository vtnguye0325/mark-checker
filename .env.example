# Required for Docker image build: Hugging Face model repo (snapshot_download)
HF_MODEL_ID=org/your-model-repo

# Optional: Hugging Face token for private/gated models (build-arg + runtime not needed if prebaked)
HF_TOKEN=

# Optional: required for POST /analyze (DeepSeek)
DEEPSEEK_API_KEY=

# Optional: comma-separated browser origins for CORS (defaults include localhost dev + Docker UI)
# CORS_ORIGINS=http://localhost:5173,http://localhost:80
